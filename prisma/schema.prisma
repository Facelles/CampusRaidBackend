datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 🎓 Користувач (Студент або Викладач)
model User {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String     @default("")
  name             String
  role             String     @default("STUDENT") // "STUDENT" | "TEACHER" | "ADMIN"
  xp               Int        @default(0)
  coins            Int        @default(0)
  titles           String[]   @default([]) // Куплені титули в магазині
  universityId     String
  university       University @relation(fields: [universityId], references: [id])
  posts            Post[]
  comments         Comment[]
  currentStreak    Int        @default(0) // поточний streak (скидається при помилці)
  maxStreak        Int        @default(0) // рекорд для лідерборду
  avatar           String     @default("👾") // Emoji avatar

  // Відношення для нових фіч
  sentMessages     Message[]     @relation("SentMessages")
  receivedMessages Message[]     @relation("ReceivedMessages")
  bossesCreated    Boss[]        @relation("BossCreator")
  bossAttempts     BossAttempt[]
  votes            PostVote[]
  friendships1     Friendship[]  @relation("UserFriends1")
  friendships2     Friendship[]  @relation("UserFriends2")
  raidMessages     RaidMessage[]
}

// 🏛️ Університет
model University {
  id    String @id @default(uuid())
  name  String @unique
  users User[]
  posts Post[]
  bosses Boss[]
}

// 📰 Пости / Треди
model Post {
  id           String     @id @default(uuid())
  title        String
  content      String
  upvotes      Int        @default(0)
  downvotes    Int        @default(0)
  createdAt    DateTime   @default(now())
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  comments     Comment[]
  votes        PostVote[]
}

// 🗳️ Голоси за пости (Reddit-style)
model PostVote {
  id        String   @id @default(uuid())
  type      String   // "UPVOTE" | "DOWNVOTE"
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

// 💬 Коментарі в тредах
model Comment {
  id        String    @id @default(uuid())
  content   String
  createdAt DateTime  @default(now())
  postId    String
  post      Post      @relation(fields: [postId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

// 👾 Бос
model Boss {
  id        String   @id @default(uuid())
  name      String
  imageUrl  String?  // URL картинки боса
  maxHp     Int
  currentHp Int
  status    String   @default("ACTIVE") // "ACTIVE" | "DEFEATED"
  inviteCode String?  @unique // Код доступу для приватних босів викладача
  creatorId String?
  creator   User?    @relation("BossCreator", fields: [creatorId], references: [id])
  universityId String?
  university   University? @relation(fields: [universityId], references: [id])
  puzzles      Puzzle[]
  attempts     BossAttempt[]
  raidMessages RaidMessage[]
}

// 🧩 Задача-пазл для боса
model Puzzle {
  id           String      @id @default(uuid())
  title        String
  description  String
  type         String      @default("SORTING") // "SORTING" | "MULTIPLE_CHOICE"
  bossId       String
  boss         Boss        @relation(fields: [bossId], references: [id])
  blocks       CodeBlock[]
  correctOrder String
}

// 🔠 Блоки коду
model CodeBlock {
  id       String @id @default(uuid())
  text     String
  puzzleId String
  puzzle   Puzzle @relation(fields: [puzzleId], references: [id])
}

// 📨 Приватні повідомлення (Чат)
model Message {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
  senderId   String
  receiverId String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// 🛒 Магазин: Товари та Титули
model ShopItem {
  id          String @id @default(uuid())
  name        String
  description String
  price       Int
  type        String // "TITLE" | "HINT"
}

// 📊 Аналітика: Спроби атак на босів
model BossAttempt {
  id        String   @id @default(uuid())
  success   Boolean
  damage    Int      @default(0)
  createdAt DateTime @default(now())
  userId    String
  bossId    String
  user      User     @relation(fields: [userId], references: [id])
  boss      Boss     @relation(fields: [bossId], references: [id])
}

// 🤝 Друзі
model Friendship {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt DateTime @default(now())

  user1     User     @relation("UserFriends1", fields: [user1Id], references: [id])
  user2     User     @relation("UserFriends2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])
}

// 💬 Публічний рейд-чат (під час боса)
model RaidMessage {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  bossId    String
  boss      Boss     @relation(fields: [bossId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
